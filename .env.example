# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the browser.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional compatibility alias for older frontend code paths.
VITE_VERTEX_AI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where this app is hosted.
APP_URL="https://your-app.onrender.com"

# PORT: Optional local override. Render injects this automatically.
PORT=3000

# ACCESS_CODE: Server-side access code for the app gate. Do not expose this with VITE_.
ACCESS_CODE=
# ACCESS_SESSION_SECRET: Secret used to sign the access session cookie.
ACCESS_SESSION_SECRET=

# SMTP: Primary outbound mail transport.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_REPLY_TO=
VITE_SMTP_FROM_EMAIL=

# RESEND_API_KEY: Your Resend API key.
RESEND_API_KEY=
# RESEND_FROM_EMAIL: The email address to send from (e.g., onboarding@resend.dev or your verified domain).
RESEND_FROM_EMAIL=
